# Database
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# App Configuration
NEXT_PUBLIC_APP_URL=https://yourdomain.com
# Optional: Google Search Console HTML tag verification (paste content value only)
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
FROM_EMAIL=noreply@yourdomain.com

# Umami Analytics
UMAMI_API_TOKEN=your_umami_api_token
UMAMI_WEBSITE_ID=0ab19376-7ad8-48fc-8f59-c69951883021

# Email Configuration (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# Square API
SQUARE_ACCESS_TOKEN=your_square_access_token
SQUARE_APPLICATION_ID=your_square_application_id
SQUARE_ENVIRONMENT=sandbox # or production

# Payment Configuration
SQUARE_WEBHOOK_SIGNATURE_KEY=your_webhook_signature_key

# Admin Access
ADMIN_PASSCODE=your_admin_passcode

# Google Reviews API (Optional)
GOOGLE_PLACES_API_KEY=your_google_places_api_key
GOOGLE_PLACE_ID=your_google_place_id

# Facebook API (Optional)
FACEBOOK_ACCESS_TOKEN=your_facebook_access_token
FACEBOOK_PAGE_ID=your_facebook_page_id

# Review Collection
REVIEW_COLLECTION_DELAY_HOURS=6 