# Copy to `.env.local` and fill in. All NEXT_PUBLIC_* vars are baked in at build time
# (set them in Vercel → Settings → Environment Variables for production).

# Canonical URL - no trailing slash. Local dev: http://localhost:3000
# Template demo on Vercel: https://restaurant-template-dfk.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Brand & SEO
NEXT_PUBLIC_BUSINESS_NAME=Your Restaurant
NEXT_PUBLIC_BRAND_WORD_PRIMARY=Your
NEXT_PUBLIC_BRAND_WORD_SECONDARY=Brand
NEXT_PUBLIC_TITLE_SUFFIX=Street Food & Catering
NEXT_PUBLIC_SITE_DESCRIPTION=A short description for search results and social previews.
NEXT_PUBLIC_SITE_KEYWORDS=restaurant, food truck, catering, your city

# Contact
NEXT_PUBLIC_PHONE_E164=+15555550100
NEXT_PUBLIC_PHONE_DISPLAY=+1 (555) 555-0100
NEXT_PUBLIC_WHATSAPP_DIGITS=15555550100
NEXT_PUBLIC_EMAIL_CONTACT=hello@example.com

# Ordering (Square, Toast, etc.)
NEXT_PUBLIC_ORDER_URL=https://example.com/order

# Address (also used in JSON-LD / geo meta)
NEXT_PUBLIC_ADDRESS_LINE=123 Main Street
NEXT_PUBLIC_ADDRESS_CITY=Your City
NEXT_PUBLIC_ADDRESS_REGION=TX
NEXT_PUBLIC_ADDRESS_STATE_NAME=Texas
NEXT_PUBLIC_ADDRESS_POSTAL=00000
NEXT_PUBLIC_ADDRESS_COUNTRY=US
NEXT_PUBLIC_ADDRESS_DISPLAY=123 Main Street, Your City, TX 00000
NEXT_PUBLIC_MAPS_URL=https://maps.google.com

# Geo (decimals)
NEXT_PUBLIC_GEO_LAT=29.76
NEXT_PUBLIC_GEO_LNG=-95.37
NEXT_PUBLIC_GEO_REGION_META=US-TX
NEXT_PUBLIC_GEO_PLACENAME=Your City
NEXT_PUBLIC_AREA_SERVED_CITY=Your City
NEXT_PUBLIC_AREA_SERVED_METRO=Your metro area

# Hours (schema.org format for structured data, e.g. Mo-Su 11:00-21:00)
NEXT_PUBLIC_OPENING_HOURS_SCHEMA=Mo-Su 11:00-21:00
NEXT_PUBLIC_HOURS_LINE1=Monday - Sunday
NEXT_PUBLIC_HOURS_LINE2=11:00 AM - 9:00 PM

# Cuisine types (comma-separated, for schema.org)
NEXT_PUBLIC_SERVES_CUISINE=Local, Comfort food
NEXT_PUBLIC_PAYMENT_METHODS=Cash, Credit Card

# Social profile URLs
NEXT_PUBLIC_SOCIAL_INSTAGRAM=https://instagram.com/yourbrand
NEXT_PUBLIC_SOCIAL_FACEBOOK=https://facebook.com/yourbrand
NEXT_PUBLIC_SOCIAL_X=https://x.com/yourbrand
NEXT_PUBLIC_SOCIAL_TIKTOK=https://tiktok.com/@yourbrand
NEXT_PUBLIC_SOCIAL_YOUTUBE=https://youtube.com/@yourbrand
NEXT_PUBLIC_TWITTER_CREATOR=@yourbrand

# Theme (browser chrome / PWA)
NEXT_PUBLIC_THEME_COLOR=#FF6B35

# Optional: Google Search Console (HTML tag content value only)
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Optional: show aggregate rating in JSON-LD (omit both to hide)
NEXT_PUBLIC_SCHEMA_RATING_VALUE=
NEXT_PUBLIC_SCHEMA_REVIEW_COUNT=

# Maps API (used in layout)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
